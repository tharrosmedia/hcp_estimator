{
  "name": "hcp-estimator",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "backend",
    "frontend"
  ],
  "scripts": {
    "dev:backend": "pnpm --filter hcp-estimator-backend dev",
    "dev:frontend": "pnpm --filter frontend dev",
    "build:backend": "pnpm --filter hcp-estimator-backend build",
    "build:frontend": "pnpm --filter frontend build",
    "build": "pnpm build:backend && pnpm build:frontend",
    "start:backend": "pnpm --filter hcp-estimator-backend start",
    "start:frontend": "pnpm --filter frontend start"
  },
  "packageManager": "pnpm@10.15.0"
}
